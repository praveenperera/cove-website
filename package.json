{
  "name": "cove-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:site": "astro dev --root apps/site",
    "build": "npm run build:site && npm run build:roadmap",
    "build:site": "astro build --root apps/site",
    "build:roadmap": "next build --turbopack",
    "start": "next start",
    "lint": "eslint .",
    "check:site": "astro check --root apps/site",
    "test": "node --test --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON 'tests/**/*.test.ts'",
    "cf:types": "wrangler types --config apps/site/wrangler.jsonc apps/site/worker-configuration.d.ts",
    "db:migrate": "npx tsx scripts/migrate.ts"
  },
  "browserslist": "defaults, not ie <= 11",
  "overrides": {
    "@orpc/client": "1.13.6",
    "next": {
      "postcss": "8.5.10"
    }
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@libsql/client": "^0.17.3",
    "@moneydevkit/nextjs": "^0.20.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "next": "^16.2.10",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "standardwebhooks": "^1.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "use-debounce": "^10.1.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/react": "^6.0.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.34.5",
    "wrangler": "^4.112.0"
  }
}
